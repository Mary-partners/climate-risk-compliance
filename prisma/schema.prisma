generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sessions     Session[]
  inquiries    Inquiry[]
  diagnostics  Diagnostic[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Inquiry {
  id               String   @id @default(cuid())
  name             String
  email            String
  organisation     String
  organisationType String
  journeyStage     String?
  biggestChallenge String?
  additionalNotes  String?
  userId           String?
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id])
}

model Diagnostic {
  id                    String   @id @default(cuid())
  institutionName       String
  contactName           String
  email                 String
  role                  String
  institutionType       String
  totalAssets           String?
  borrowerCount         String?
  hasEsgTeam            String?
  hasSubmittedReports   String?
  collectsClimateData   String?
  kgftClassified        String?
  pcafMeasured          String?
  frameworks            String[] @default([])
  pressingDeadline      String?
  topChallenges         String[] @default([])
  additionalInfo        String?
  readinessScore        Int?
  userId                String?
  createdAt             DateTime @default(now())
  user                  User?    @relation(fields: [userId], references: [id])
}

model Institution {
  id              String   @id @default(cuid())
  name            String
  type            String
  tier            String?
  assets          String?
  ownership       String?
  members         String?
  premiums        String?
  sector          String?
  sustainData     String?
  climateReady    String?
  createdAt       DateTime @default(now())
}
