DATABASE_URL="postgresql://user:password@host:5432/climate_risk_compliance?sslmode=require"

# Admin dashboard access (optional). Comma-separated emails allowed into /internal/admin.
# Defaults to mary@cfolead.solutions and stephen.mutimba@eclimateadvisory.com if unset.
# ADMIN_EMAILS="mary@cfolead.solutions,stephen.mutimba@eclimateadvisory.com"

# Notion mirror (optional). When set, new accounts / diagnostics / inquiries are copied
